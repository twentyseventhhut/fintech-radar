# ─────────────────────────────────────────────────────────────────────────────
# Fintech Radar — configuration template.  Copy to pipeline/.env for LOCAL runs
# (pipeline/.env is gitignored).  In GitHub Actions set the same names as repo
# Secrets (the sensitive ones) and repo Variables (the non-secret ones) — see README.
# Nothing here is a real key; fill in your own.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI runtime (required) ────────────────────────────────────────────────────
# Claude Code on a Claude Max subscription (no per-token API billing). Get the token with
# `claude setup-token` in an interactive Claude Code session, or use an Anthropic API key.
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_MODEL=claude-opus-4-8[1m]

# ── Embeddings for semantic search (required for the index / researcher) ──────
# Default provider is OpenRouter; EMBED_BASE_URL/EMBED_API_KEY let you point at any
# OpenAI-compatible embeddings endpoint instead.
OPENROUTER_API_KEY=
EMBED_MODEL=qwen/qwen3-embedding-8b
EMBED_DIM=1024
# EMBED_BASE_URL=https://openrouter.ai/api/v1
# EMBED_API_KEY=                      # falls back to OPENROUTER_API_KEY

# ── Source 1: newsletter inbox (IMAP) ─────────────────────────────────────────
# A mailbox you subscribe your newsletters to. IMAP_PASS should be an app-password.
IMAP_HOST=imap.your-mail-provider.com
IMAP_PORT=993
IMAP_USER=you@example.com
IMAP_PASS=
IMAP_FOLDER=INBOX

# ── Source 2: Telegram channels ──────────────────────────────────────────────
# tg_ingest.py reads posts from the channels you configure (see pipeline/tg_ingest.py).

# ── Source 3: Investor-Relations documents (optional) ─────────────────────────
# EDGAR is public (no key). Private IR materials are mirrored to Google Drive via rclone.
# RCLONE_CONFIG = the contents of an `rclone config` remote (OAuth). RCLONE_REMOTE = its name.
RCLONE_REMOTE=irdrive:
# RCLONE_CONFIG is multi-line — set it as a GitHub Secret, not here.
IR_DUE_CAP=20
IR_DISC_TIMEOUT=6000

# ── Output: daily digest → Telegram channel ──────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL=@your_channel_or_-100id
TELEGRAPH_TOKEN=                       # optional; auto-created if empty
TELEGRAPH_AUTHOR=Fintech Radar

# ── Output: on-demand researcher bot (optional) ───────────────────────────────
RESEARCH_BOT_TOKEN=
RESEARCH_ALLOWED_CHATS=YOUR_TELEGRAM_CHAT_ID   # csv of allowed chat ids (message the bot to learn yours)
# RESEARCH_TIMEOUT=3000
